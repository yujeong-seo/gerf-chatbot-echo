OPENAI_API_KEY = sk-...

# Project Settings → API → Project URL
SUPABASE_URL = https://<project-ref>.supabase.co
# Project Settings → API → service_role secret key
SUPABASE_KEY = eyJ...

# airtable.com/create/tokens — needs data.records:write scope on your base
AIRTABLE_API_KEY = pat...
# Base ID from the Airtable URL: airtable.com/appXXXXXXXX/...
AIRTABLE_BASE_ID = app...
# Name of the CRM table inside that base
AIRTABLE_TABLE_NAME = Registrations